---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Your New Business", description = "I want you to make a business that is a newsletter. It's going to be in the skincare industry. All about how to stay young and healthy. 
We'll also interview peeps in the biz and throw their interviews in the newsletter. Gotta have personality and flavor. 

Monetize by affiliate and ads. With future ability to sell our own products" } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Your New Business",
      "description": "I want you to make a business that is a newsletter. It's going to be in the skincare industry. All about how to stay young and healthy. 
We'll also interview peeps in the biz and throw their interviews in the newsletter. Gotta have personality and flavor. 

Monetize by affiliate and ads. With future ability to sell our own products",
      "url": "https://glow-grow-newsletter.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
