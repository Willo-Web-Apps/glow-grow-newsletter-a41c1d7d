---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Dermly — The Skincare Newsletter That Actually Tells You the Truth",
  description = "Weekly deep-dives, expert interviews, and no-BS product picks to help you glow smarter and age on your own terms. Join 47,000+ women who trust Dermly."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Dermly",
      "description": "The weekly skincare newsletter for women who want real answers about aging beautifully — not influencer fluff. Evidence-based education, exclusive dermatologist interviews, and honest product picks.",
      "url": "https://glow-grow-newsletter.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
